<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.DiceRollerPage"
             x:DataType="vm:DiceRollerViewModel"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20,30,20,30">
        
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="5" Margin="0,0,0,25">
            <Label Text="DICE ROLLER" FontSize="24" FontAttributes="Bold" CharacterSpacing="2" HorizontalOptions="Center" TextColor="{StaticResource Primary}" />
            <BoxView HeightRequest="2" WidthRequest="60" Color="{StaticResource Secondary}" CornerRadius="1" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,10">
            <Border Grid.Column="0" 
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    StrokeThickness="1" Padding="15,10">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Label Text="DICE" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" CharacterSpacing="1.5"/>
                    <Picker ItemsSource="{x:Static vm:DiceRollerViewModel.DiceOptions}" 
                            SelectedItem="{Binding SelectedDice}" 
                            FontSize="22" FontAttributes="Bold" 
                            TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                            Title="Select Dice" 
                            Margin="0,-5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1" 
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    StrokeThickness="1" Padding="15,10">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Label Text="MODIFIER" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" CharacterSpacing="1.5"/>
                    <Entry Text="{Binding Modifier}" 
                           Keyboard="Numeric" 
                           FontSize="22" FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                           Margin="0,-5,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="2" VerticalOptions="Center" HorizontalOptions="Center">
            
            <Border HeightRequest="280" WidthRequest="280" BackgroundColor="Transparent" 
                    Stroke="{StaticResource Primary}" StrokeThickness="2"
                    HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.4">
                <Border.StrokeShape><RoundRectangle CornerRadius="140" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,0" Radius="50" Opacity="0.8" />
                </Border.Shadow>
            </Border>
            
            <Border HeightRequest="250" WidthRequest="250" BackgroundColor="Transparent" 
                    Stroke="{StaticResource Secondary}" StrokeThickness="3" StrokeDashArray="3,4"
                    HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.7">
                <Border.StrokeShape><RoundRectangle CornerRadius="125" /></Border.StrokeShape>
            </Border>

            <Border HeightRequest="220" WidthRequest="220" 
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" StrokeThickness="1"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="110" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="{AppThemeBinding Light=0.1, Dark=0.5}" />
                </Border.Shadow>
                
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                    <Label Text="{Binding ResultText}" FontSize="84" FontAttributes="Bold" 
                           HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>
                    
                    <Label Text="{Binding CalculationText}" FontSize="16" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           TextColor="{StaticResource Secondary}" Margin="0,-5,0,0"/>
                </VerticalStackLayout>
            </Border>
            
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,-45" Spacing="8">
                <Border HeightRequest="24" WidthRequest="24" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=Transparent, Dark={StaticResource SurfaceLight}}" VerticalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Label Text="📳" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Shake to roll" FontSize="14" FontAttributes="Italic" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="Auto, *" ColumnSpacing="15" Margin="0,30,0,0">
            <Button Grid.Column="0" Text="✕" FontSize="20" WidthRequest="64" HeightRequest="64" CornerRadius="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                    TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" 
                    Command="{Binding CloseCommand}" />
            
            <Button Grid.Column="1" Text="ROLL THE DICE" FontSize="18" FontAttributes="Bold" CharacterSpacing="1"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" 
                    Command="{Binding RollCommand}" CornerRadius="32" HeightRequest="64">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,6" Radius="12" Opacity="0.5" />
                </Button.Shadow>
            </Button>
        </Grid>

    </Grid>
</ContentPage>