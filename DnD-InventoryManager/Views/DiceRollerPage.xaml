<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.DiceRollerPage"
             x:DataType="vm:DiceRollerViewModel"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="25" Margin="0, 20, 0, 0">
        
        <Label Grid.Row="0" Text="🎲 Dice Roller" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}" />

        <VerticalStackLayout Grid.Row="1" Spacing="35" VerticalOptions="Center">
            
            <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                <VerticalStackLayout Grid.Column="0" Spacing="8">
                    <Label Text="DICE" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" CharacterSpacing="1"/>
                    <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent" Padding="10,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Picker ItemsSource="{x:Static vm:DiceRollerViewModel.DiceOptions}" SelectedItem="{Binding SelectedDice}" FontSize="18" HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="8">
                    <Label Text="MODIFIER" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" CharacterSpacing="1"/>
                    <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent" Padding="10,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Entry Text="{Binding Modifier}" Keyboard="Numeric" HorizontalTextAlignment="Center" FontSize="18"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Stroke="{StaticResource Primary}" StrokeThickness="2" HeightRequest="160" Padding="15">
                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="15" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                    <Label Text="{Binding ResultText}" FontSize="76" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                    <Label Text="{Binding CalculationText}" FontSize="15" HorizontalOptions="Center" TextColor="{StaticResource Secondary}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15">
            <Button Grid.Column="0" Text="Close" BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" Command="{Binding CloseCommand}" CornerRadius="12" HeightRequest="55"/>
            <Button Grid.Column="1" Text="Roll" BackgroundColor="{StaticResource Primary}" TextColor="White" FontAttributes="Bold" Command="{Binding RollCommand}" CornerRadius="12" HeightRequest="55"/>
        </Grid>
    </Grid>
</ContentPage>