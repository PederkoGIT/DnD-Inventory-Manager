<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.ItemDetailPage"
             x:DataType="vm:ItemDetailViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
             Title="{Binding Title}">
             
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Command="{Binding GoToEditItemCommand}" Priority="0" />
        <ToolbarItem Text="Delete" Command="{Binding DeleteItemCommand}" Priority="1" />
    </ContentPage.ToolbarItems>
    
    <Grid>
        <ScrollView>
            <Border Margin="15,15,15,100" 
                    Padding="20"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource PrimaryDark}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <Border HeightRequest="90" WidthRequest="90"
                            Stroke="{StaticResource Primary}" StrokeThickness="2"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="45" />
                        </Border.StrokeShape>
                        <Image Source="{Binding Item.ImagePath}" Aspect="AspectFill"  />
                    </Border>
                    
                    <Label Text="{Binding Item.Name}" 
                           FontSize="26" FontAttributes="Bold" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                    
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="{Binding Item.Category, StringFormat='{0} 🏷️'}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                        <Label Text="•" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding Item.Weight, StringFormat='{0} lb'}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                        <Label Text="•" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding Item.Quantity, StringFormat='Amount: {0}'}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                    </HorizontalStackLayout>
                    
                    <Label Text="{Binding Item.Description}" 
                           HorizontalOptions="Start" FontSize="14" 
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>
        </ScrollView>

        <Border HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="20,30" Padding="10"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="15" Opacity="0.2" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="15">
                <Button Text="Share via NFC"
                        FontSize="14" FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="50" CornerRadius="25"
                        Padding="25,0"
                        Command="{Binding WriteToNfcCommand}">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="8" Opacity="0.4" />
                    </Button.Shadow>
                </Button>
                <Button Text="Show QR Code"
                        FontSize="14" FontAttributes="Bold"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="50" CornerRadius="25"
                        Padding="25,0"
                        Command="{Binding ShowQrCodeCommand}">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Secondary}" Offset="0,4" Radius="8" Opacity="0.4" />
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>
        </Border>

        <Grid BackgroundColor="#A0000000" 
              IsVisible="{Binding IsWaitingForNfc}" 
              ZIndex="100">
            
            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="35" WidthRequest="300" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="25">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" HeightRequest="45" WidthRequest="45" />
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ready to Share" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" HorizontalOptions="Center" />
                        <Label Text="Approach an NFC tag to write item data." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    
                    <Button Text="Cancel" Command="{Binding CancelNfcCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" CornerRadius="12" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>