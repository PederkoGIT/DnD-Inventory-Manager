<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.ItemEditPage"
             x:DataType="vm:ItemEditViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             Title="{Binding Title}">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Template API" Command="{Binding GetItemFromApiCommand}"/>
    </ContentPage.ToolbarItems>
    
    <Grid>
        <Grid RowDefinitions="Auto, *, Auto" Padding="20,15,20,25">
                
            <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center" Margin="0,0,0,15">
                <Border HeightRequest="120" WidthRequest="120" Stroke="{StaticResource Primary}" StrokeThickness="2">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}" />
                    </Border.Shadow>
                    <Image Source="{Binding SelectedImagePath}" Aspect="AspectFill" />
                </Border>
                <Button Text="Change Image" Command="{Binding PickImageCommand}" BackgroundColor="Transparent" 
                        TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="14" Padding="0,5"/>
            </VerticalStackLayout>

            <ScrollView Grid.Row="1" VerticalOptions="Start">
                <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" 
                        Padding="20" Margin="0,0,0,10">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">
                        
                        <VerticalStackLayout Spacing="6">
                            <Label Text="ITEM NAME" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Entry Placeholder="e.g. Health Potion..." Text="{Binding ItemModel.Name}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                        <Label Text="CATEGORY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                        
                        <Grid ColumnDefinitions="*, 45" ColumnSpacing="10">
                            
                            <Border Grid.Column="0" Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="15,0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding NewCategory}" VerticalOptions="Center" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                            </Border>
                            
                            <Border Grid.Column="1" Stroke="{StaticResource Primary}" StrokeThickness="1" BackgroundColor="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenCategoryMenuCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="⋮" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                            </Border>

                        </Grid>
                    </VerticalStackLayout>
                        
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="AMOUNT" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" HorizontalOptions="Center"/>
                                <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Entry Text="{Binding NewQuantity}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>
                                </Border>
                                <Stepper Value="{Binding NewQuantity}" Minimum="1" Maximum="999" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="WEIGHT (LB)" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" HorizontalOptions="Center"/>
                                <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Entry Text="{Binding NewWeight}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>
                                </Border>
                                <Stepper Value="{Binding NewWeight}" Minimum="0" Maximum="999" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            
                        </Grid>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="DESCRIPTION" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Editor Placeholder="Describe your item here..." Text="{Binding ItemModel.Description}" 
                                        AutoSize="TextChanges" MinimumHeightRequest="80"
                                        FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                            </Border>
                        </VerticalStackLayout>
                        
                    </VerticalStackLayout>
                </Border>
            </ScrollView>

            <Button Grid.Row="2" Text="SAVE ITEM" Command="{Binding SaveCommand}" 
                    BackgroundColor="{StaticResource Primary}" TextColor="White" 
                    HeightRequest="55" CornerRadius="16" FontAttributes="Bold" CharacterSpacing="1">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="10" Opacity="0.4" />
                </Button.Shadow>
            </Button>
        </Grid>   
        
        <Grid BackgroundColor="#B3000000" IsVisible="{Binding IsCategoryMenuVisible}" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseCategoryMenuCommand}" />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="25,30" WidthRequest="320" StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="15">
                    <Label Text="Category Options" FontSize="20" FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" 
                           HorizontalOptions="Center" Margin="0,0,0,10" />
                    
                    <Button Text="Add New Category" Command="{Binding AddCategoryCommand}" 
                            BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                            TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" 
                            CornerRadius="14" FontAttributes="Bold" HeightRequest="48"/>
                    
                    <Button Text="Rename Current" Command="{Binding RenameCategoryCommand}" IsVisible="{Binding CanDeleteCategory}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                            TextColor="{StaticResource Secondary}" 
                            CornerRadius="14" FontAttributes="Bold" HeightRequest="48"/>
                    
                    <Button Text="Delete Current" Command="{Binding DeleteCategoryCommand}" IsVisible="{Binding CanDeleteCategory}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                            TextColor="{StaticResource Primary}" 
                            CornerRadius="14" FontAttributes="Bold" HeightRequest="48"/>
                    
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" Margin="0,10"/>
                    
                    <Button Text="Cancel" Command="{Binding CloseCategoryMenuCommand}" 
                            BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" 
                            FontAttributes="Bold" HeightRequest="48"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
        <Grid BackgroundColor="#B3000000" IsVisible="{Binding IsPromptVisible}" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelPromptCommand}" />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="25,30" WidthRequest="320" StrokeThickness="0">
                <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="20">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding PromptTitle}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" HorizontalOptions="Center" />
                        <Label Text="{Binding PromptMessage}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    
                    <Border Stroke="{StaticResource Primary}" BackgroundColor="Transparent" Padding="15,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <Entry Text="{Binding PromptInputText}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                    </Border>
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="Cancel" Command="{Binding CancelPromptCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" CornerRadius="12" FontAttributes="Bold" HeightRequest="48"/>
                        <Button Grid.Column="1" Text="{Binding PromptConfirmText}" Command="{Binding ConfirmPromptCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="12" FontAttributes="Bold" HeightRequest="48"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid BackgroundColor="#B3000000" IsVisible="{Binding IsAlertVisible}" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelAlertCommand}" />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="25,30" WidthRequest="320" StrokeThickness="0">
                <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding AlertTitle}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" HorizontalOptions="Center" />
                        <Label Text="{Binding AlertMessage}" FontSize="15" LineHeight="1.3" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="Cancel" Command="{Binding CancelAlertCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" CornerRadius="12" FontAttributes="Bold" HeightRequest="48"/>
                        <Button Grid.Column="1" Text="{Binding AlertConfirmText}" Command="{Binding ConfirmAlertCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="12" FontAttributes="Bold" HeightRequest="48"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid BackgroundColor="#B3000000" IsVisible="{Binding IsSelectCategoryVisible}" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelCategorySheetCommand}" />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="25,30" WidthRequest="320" StrokeThickness="0">
                <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="15">
                    <Label Text="Select Category" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" HorizontalOptions="Center" Margin="0,0,0,10" />
                    
                    <ScrollView MaximumHeightRequest="250">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding DisplayCategories}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Text="{Binding .}" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ItemEditViewModel}}, Path=PickCategoryOptionCommand}" 
                                            CommandParameter="{Binding .}" 
                                            BackgroundColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                                            TextColor="{StaticResource Primary}" 
                                            CornerRadius="14" FontAttributes="Bold" HeightRequest="48"/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                    
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" Margin="0,10"/>
                    
                    <Button Text="Cancel" Command="{Binding CancelCategorySheetCommand}" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontAttributes="Bold" HeightRequest="48"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>