<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.ItemEditPage"
             x:DataType="vm:ItemEditViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
             Title="{Binding Title}">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Template" Command="{Binding GetItemFromApiCommand}"/>
    </ContentPage.ToolbarItems>
    
    <ContentPage.Content>
        <Grid RowDefinitions="auto, auto, *, auto" Padding="25" RowSpacing="20">
            <VerticalStackLayout Grid.Row="0" Spacing="20">
                <Border HorizontalOptions="Center" HeightRequest="160" WidthRequest="160"
                        Stroke="{StaticResource Primary}" StrokeThickness="2">
                    <Border.StrokeShape><RoundRectangle CornerRadius="80" /></Border.StrokeShape>
                    <Image Source="{Binding ItemModel.ImagePath}" Aspect="AspectFill" />
                </Border>
            
                <Button Text="Select Image" Command="{Binding PickImageCommand}" 
                        BackgroundColor="{StaticResource Secondary}" 
                        TextColor="{StaticResource SecondaryDarkText}" />

                <VerticalStackLayout Spacing="5">
                    <Label Text="Item name" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                    <Entry Placeholder="Name..." Text="{Binding ItemModel.Name}" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="5">
                    <Label Text="Category" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                    
                    <Grid ColumnDefinitions="2*, *">
                        <Entry Grid.Column="0" Placeholder="Category" Text="{Binding NewCategory}" />
                        <Picker Grid.Column="1"
                                Title="Category"
                                ItemsSource="{Binding AllCategories}"
                                SelectedItem="{Binding PickerCategory}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                                FontSize="14"/>
                    </Grid>
                </VerticalStackLayout>
                
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Amount" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Entry Text="{Binding NewQuantity}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center"/>
                        <Stepper Value="{Binding NewQuantity}" Minimum="0" Maximum="999" VerticalOptions="End"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Weight in pounds" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Entry Text="{Binding NewWeight}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center"/>
                        <Stepper Value="{Binding NewWeight}" Minimum="0" Maximum="999" VerticalOptions="End"/>
                    </VerticalStackLayout>
                </Grid>
                    
                    
            </VerticalStackLayout>

            <Label Grid.Row="1"
                   Text="Description" 
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            
            <Editor Grid.Row="2" 
                    Placeholder="Description..." 
                    Text="{Binding ItemModel.Description}" 
                    VerticalOptions="Fill"/>
            
            <Button Grid.Row="3"
                    Text="Save Item" 
                    Command="{Binding SaveCommand}" 
                    Margin="0,20,0,0" />
        </Grid>
            
    </ContentPage.Content>
</ContentPage>