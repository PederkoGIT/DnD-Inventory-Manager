<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             xmlns:models="clr-namespace:DnD_InventoryManager.Models" 
             x:DataType="vm:MainViewModel" 
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
             x:Class="DnD_InventoryManager.Views.MainPage">

    <Grid>
        <CollectionView ItemsSource="{Binding Characters}" 
                        SelectionMode="None"
                        EmptyView="You have no characters. Tap '+' to add characters.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CharacterModel">
                    <Border Margin="15,8" 
                            Padding="15" 
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource PrimaryDark}}" 
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=GoToCharacterDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                            
                            <Border Grid.Column="0"
                                    HeightRequest="76" WidthRequest="76"
                                    Stroke="{StaticResource Primary}" StrokeThickness="2"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="38" />
                                </Border.StrokeShape>
                                <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}" 
                                       FontAttributes="Bold" FontSize="18" 
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                            
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Strength, StringFormat='STR: {0}'}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                                    <Label Text="•" TextColor="{StaticResource Gray400}" />
                                    <Label Text="{Binding Size}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding CarryingCapacity, StringFormat='Max Load: {0} lb'}" 
                                       FontAttributes="Bold" FontSize="14"
                                       TextColor="{StaticResource Secondary}" 
                                       Margin="0,4,0,0" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="20,30" Padding="10"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                StrokeThickness="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="15" Opacity="0.2" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="15">
                <Button Text="🎲"
                        FontSize="24"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        HeightRequest="50" WidthRequest="50" CornerRadius="25"
                        Command="{Binding ShowDiceRollerCommand}" />

                <Button Text="NFC"
                        FontSize="14" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        HeightRequest="50" WidthRequest="50" CornerRadius="25"
                        Command="{Binding ListenForNfcCommand}" />

                <Button Text="+"
                        FontSize="24" FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="50" WidthRequest="50" CornerRadius="25"
                        Command="{Binding GoToAddCharacterCommand}">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="8" Opacity="0.4" />
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>
        </Border>
        
        <Grid BackgroundColor="#A0000000" 
              IsVisible="{Binding IsWaitingForNfc}" 
              ZIndex="100">
            
            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="35" WidthRequest="300" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="25">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" HeightRequest="45" WidthRequest="45" />
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ready to Read" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" HorizontalOptions="Center" />
                        <Label Text="Approach an NFC tag to load a character." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    
                    <Button Text="Cancel" Command="{Binding CancelNfcCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" CornerRadius="12" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>