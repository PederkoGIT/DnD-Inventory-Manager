<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             xmlns:models="clr-namespace:DnD_InventoryManager.Models" 
             x:DataType="vm:MainViewModel" 
             Title="{Binding Title}"
             x:Class="DnD_InventoryManager.Views.MainPage">

    <Grid RowDefinitions="*, Auto">
        
        <CollectionView ItemsSource="{Binding Characters}" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Character"> 
                    <Label Text="{Binding Name}" Padding="20" FontSize="Large" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Add Character" 
                Grid.Row="1"
                Command="{Binding GoToAddCharacterCommand}"
                Margin="20" />
    </Grid>
</ContentPage>