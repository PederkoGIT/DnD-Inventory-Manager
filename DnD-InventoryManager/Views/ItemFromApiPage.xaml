<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:DnD_InventoryManager.Models" 
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.ItemFromApiPage"
             x:DataType="vm:ItemFromApiVIewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             Title="DnD 5e Database">
    
    <Grid RowDefinitions="Auto, *, Auto" Padding="20,15,20,25">
            
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="20,15,20,20" Margin="0,0,0,15">
            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}" /></Border.Shadow>

            <VerticalStackLayout Spacing="15">
                
                <VerticalStackLayout Spacing="6">
                    <Label Text="DATABASE CATEGORY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                    <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Picker Title="Select category..." ItemsSource="{x:Static vm:ItemFromApiVIewModel.AllCategories}" SelectedItem="{Binding ItemCategory}" 
                                FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </Border>
                </VerticalStackLayout>

                <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}" StrokeThickness="1" HeightRequest="45" Padding="12,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="🔍" FontSize="14" VerticalOptions="Center" Margin="0,0,8,0" Opacity="0.5"/>
                        <Entry Grid.Column="1" Text="{Binding SearchedItem}" Placeholder="Search official items..." ClearButtonVisibility="WhileEditing" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding EquipmentApiList}" SelectionMode="Single" SelectedItem="{Binding SelectedItem}">
            
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                    <Label Text="📜" FontSize="48" HorizontalOptions="Center" Opacity="0.5"/>
                    <Label Text="No items found" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>
                    <Label Text="Try a different search term or category." FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ItemListApiModel">
                    <Border Margin="5,6" Padding="15" 
                            Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        
                        <!-- Visual State Manager na zvýraznenie kliknutej (zvolenej) položky -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal" />
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <!-- Keď sa položka vyberie, zmení sa orámovanie na červenú a pozadie sa jemne stmaví -->
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="🔸" VerticalOptions="Center" Margin="0,0,12,0" FontSize="10" TextColor="{StaticResource Secondary}"/>
                            <Label Grid.Column="1" Text="{Binding Name}" 
                                   FontAttributes="Bold" FontSize="16" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- SPODNÁ ČASŤ: Tlačidlo pre potvrdenie -->
        <Button Grid.Row="2" Text="USE TEMPLATE" Command="{Binding GetItemFromApiCommand}" 
                BackgroundColor="{StaticResource Primary}" TextColor="White" 
                HeightRequest="55" CornerRadius="16" FontAttributes="Bold" CharacterSpacing="1" Margin="0,15,0,0">
            <Button.Shadow>
                <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="10" Opacity="0.4" />
            </Button.Shadow>
        </Button>
        
    </Grid>
</ContentPage>