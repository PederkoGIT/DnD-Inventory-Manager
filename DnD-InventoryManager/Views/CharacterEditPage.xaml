<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             x:Class="DnD_InventoryManager.Views.CharacterEditPage"
             x:DataType="vm:CharacterEditViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20,15,20,25">
            
        <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center" Margin="0,0,0,15">
            <Border HeightRequest="120" WidthRequest="120" Stroke="{StaticResource Primary}" StrokeThickness="2">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}" />
                </Border.Shadow>
                <Image Source="{Binding SelectedImagePath}" Aspect="AspectFill" />
            </Border>
            <Button Text="Change Portrait" Command="{Binding PickImageCommand}" BackgroundColor="Transparent" 
                    TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="14" Padding="0,5"/>
        </VerticalStackLayout>

        <Border Grid.Row="1" VerticalOptions="Start"
                Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" 
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" 
                Padding="20">
            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                
                <VerticalStackLayout Spacing="6">
                    <Label Text="CHARACTER NAME" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                    <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="e.g. Gimli..." Text="{Binding Name}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="STRENGTH (STR)" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
                        <Border Grid.Column="0" Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Entry Text="{Binding Strength}" Keyboard="Numeric" MaxLength="2" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                        </Border>
                        <Stepper Grid.Column="1" Value="{Binding Strength}" Minimum="1" Maximum="30" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="SIZE CLASS" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                    <Border Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" BackgroundColor="Transparent" Padding="12,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Picker Title="Select size..." ItemsSource="{x:Static vm:CharacterEditViewModel.AllSizes}" SelectedItem="{Binding SelectedSize}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
                    </Border>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </Border>

        <Button Grid.Row="2" Text="SAVE CHARACTER" Command="{Binding SaveCommand}" 
                BackgroundColor="{StaticResource Primary}" TextColor="White" 
                HeightRequest="55" CornerRadius="16" FontAttributes="Bold" CharacterSpacing="1">
            <Button.Shadow>
                <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="10" Opacity="0.4" />
            </Button.Shadow>
        </Button>
            
    </Grid>
</ContentPage>