<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             xmlns:models="clr-namespace:DnD_InventoryManager.Models" 
             x:Class="DnD_InventoryManager.Views.CharacterDetailPage"
             x:DataType="vm:CharacterDetailViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Command="{Binding GoToEditCharacterCommand}" Priority="0" />
        <ToolbarItem Text="Delete" Command="{Binding DeleteCharacterCommand}" Priority="1" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" 
                Margin="15" 
                Padding="15"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                    
                    <Border Grid.Column="0"
                            HeightRequest="100"
                            WidthRequest="100"
                            StrokeThickness="0"
                            HorizontalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Image Source="{Binding Character.ImagePath}" 
                               Aspect="AspectFill"  />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding Character.Name}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                        
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Character.Strength, StringFormat='STR: {0}'}" 
                                   FontSize="12" 
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="•" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding Character.Size, StringFormat='Size: {0}'}" 
                                   FontSize="12" 
                                   TextColor="{StaticResource Gray500}" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding Character.CarryingCapacity, StringFormat='{0} lb'}" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource Primary}" 
                               Margin="0,5,0,0" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="5">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Inventory Load" FontSize="11" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Column="1" Text="{Binding Character.CarryingCapacity, StringFormat='0 / {0} lb'}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                    </Grid>
                    <ProgressBar Progress="0.0" 
                                 ProgressColor="{StaticResource Primary}"
                                 ScaleY="2" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="1" Padding="15,0,15,15" Spacing="10">
            <Label Text="Items" FontSize="20" FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
            
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" 
                    StrokeDashArray="4,2"
                    Padding="40"
                    VerticalOptions="FillAndExpand">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <!-- <Label Text="Inventory is empty. Tap '+' to add items."  -->
                <!--        HorizontalOptions="Center"  -->
                <!--        TextColor="{StaticResource Gray500}" /> -->
                <CollectionView ItemsSource="{Binding Items}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ItemModel">
                            <Border Margin="15,8" 
                            Padding="12" 
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" 
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                                </Border.Shadow>

                                <Border.GestureRecognizers>
                                    <!-- <TapGestureRecognizer  -->
                                    <!--     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=GoToCharacterDetailCommand}" -->
                                    <!--     CommandParameter="{Binding .}" /> -->
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                                    
                                    <Border Grid.Column="0"
                                            HeightRequest="80"
                                            WidthRequest="80"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ImagePath}" 
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold" 
                                               FontSize="18" 
                                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Quantity, StringFormat='Count: {0}'}" 
                                                   FontSize="11" 
                                                   TextColor="{StaticResource Gray500}" />
                                            <Label Text="•" TextColor="{StaticResource Gray400}" />
                                            <Label Text="{Binding Weight, StringFormat='{0} lb'}" 
                                                   FontSize="11" 
                                                   TextColor="{StaticResource Gray500}" />
                                        </HorizontalStackLayout>    
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Margin="20"
                             Spacing="15"
                             ZIndex="1">
            <Button Text="NFC"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                    HeightRequest="60"
                    WidthRequest="60"
                    CornerRadius="30"
                    Command="{Binding WriteToNfcCommand}">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
                </Button.Shadow>
            </Button>

            <Button Text="+"
                    FontSize="24"
                    FontAttributes="Bold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    HeightRequest="60"
                    WidthRequest="60"
                    CornerRadius="30"
                    Command="{Binding GoToAddItemCommand}">
                
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>
    </Grid>
</ContentPage>