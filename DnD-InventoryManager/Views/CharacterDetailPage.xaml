<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DnD_InventoryManager.ViewModels"
             xmlns:models="clr-namespace:DnD_InventoryManager.Models" 
             x:Class="DnD_InventoryManager.Views.CharacterDetailPage"
             x:DataType="vm:CharacterDetailViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Command="{Binding GoToEditCharacterCommand}" Priority="0" />
        <ToolbarItem Text="Delete" Command="{Binding DeleteCharacterCommand}" Priority="1" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" 
                Margin="15,15,15,5" 
                Padding="20"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource PrimaryDark}}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="20">
                    
                    <Border Grid.Column="0"
                            HeightRequest="90" WidthRequest="90"
                            Stroke="{StaticResource Primary}" StrokeThickness="2"
                            HorizontalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="45" />
                        </Border.StrokeShape>
                        <Image Source="{Binding Character.ImagePath}" Aspect="AspectFill"  />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding Character.Name}" 
                               FontSize="26" FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                        
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding Character.Strength, StringFormat='STR: {0}'}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                            <Label Text="•" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding Character.Size, StringFormat='{0}'}" FontSize="13" TextColor="{StaticResource Gray500}" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding Character.CarryingCapacity, StringFormat='Max Load: {0} lb'}" 
                               FontSize="16" FontAttributes="Bold" 
                               TextColor="{StaticResource Secondary}" 
                               Margin="0,5,0,0" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="INVENTORY LOAD" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" CharacterSpacing="1" />
                        <Label Grid.Column="1" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" >
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} / {1} lb">
                                    <Binding Path="CurrentLoad" />
                                    <Binding Path="Character.CarryingCapacity" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>
                    
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" HeightRequest="8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <ProgressBar Progress="{Binding CurrentLoadPercentage}" ProgressColor="{StaticResource Primary}" />
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="1" Padding="20,15,20,0" Spacing="15">
            <Label Text="Items" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" 
                    StrokeThickness="0"
                    Padding="40"
                    VerticalOptions="FillAndExpand">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
              
                <CollectionView ItemsSource="{Binding Items}"
                                SelectionMode="None"
                                EmptyView="Inventory is empty. Tap '+' to add items.">
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ItemModel">
                            <Border Margin="15,8" 
                            Padding="12" 
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" 
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                                </Border.Shadow>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CharacterDetailViewModel}}, Path=GoToItemDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                                    
                                    <Border Grid.Column="0"
                                            HeightRequest="80"
                                            WidthRequest="80"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ImagePath}" 
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold" 
                                               FontSize="18" 
                                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Quantity, StringFormat='Count: {0}'}" 
                                                   FontSize="11" 
                                                   TextColor="{StaticResource Gray500}" />
                                            <Label Text="•" TextColor="{StaticResource Gray400}" />
                                            <Label Text="{Binding Weight, StringFormat='{0} lb'}" 
                                                   FontSize="11" 
                                                   TextColor="{StaticResource Gray500}" />
                                        </HorizontalStackLayout>    
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>
        
        <HorizontalStackLayout Grid.Row="1"
                               HorizontalOptions="Center"
                               VerticalOptions="End"
                               Margin="20,20,20,30"
                               Spacing="15"
                               ZIndex="10">
            <Button Text="QR"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                    HeightRequest="60"
                    WidthRequest="60"
                    CornerRadius="30"
                    Command="{Binding ScanItemQrCommand}">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
                </Button.Shadow>
            </Button>
            
            <Button Text="NFC"
                    FontSize="14" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"
                    TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                    HeightRequest="50" WidthRequest="50" CornerRadius="25"
                    Command="{Binding ListenForNfcCommand}" />

            <Button Text="+"
                    FontSize="24" FontAttributes="Bold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    HeightRequest="50" WidthRequest="50" CornerRadius="25"
                    Command="{Binding GoToAddItemCommand}">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="8" Opacity="0.4" />
                </Button.Shadow>
            </Button>
        </HorizontalStackLayout>
        
        <Grid Grid.Row="0" Grid.RowSpan="2" 
              BackgroundColor="#A0000000" 
              IsVisible="{Binding IsWaitingForNfc}" 
              ZIndex="100">
            
            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>
            
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="35" WidthRequest="300" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="25">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" HeightRequest="45" WidthRequest="45" />
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ready to Read" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" HorizontalOptions="Center" />
                        <Label Text="Approach an NFC tag to write character data." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    
                    <Button Text="Cancel" Command="{Binding CancelNfcCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" CornerRadius="12" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>